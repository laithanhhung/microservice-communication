                        "Correlation IDs link async responses to their original requests — essential in Async Request-Response where responses arrive out-of-band.",
                },
                {
                    q: "Main drawback of Shared Data pattern?",
                    opts: [
                        "High coupling",
                        "Too complex",
                        "High latency from polling",
                        "Cannot handle large data",
                    ],
                    correct: 2,
                    explain:
                        "The reader polls on an interval to detect new data, introducing delay between write time and processing time.",
                },
                {
                    q: "'CreateShipment' event name is wrong because:",
                    opts: [
                        "Wrong format",
                        "Events are past-tense ('ShipmentCreated'), not commands",
                        "Too long",
                        "Missing timestamp",
                    ],
                    correct: 1,
                    explain:
                        "Events describe facts that already happened. 'CreateShipment' is a command. Use 'ShipmentCreated' to respect inversion of responsibility.",
                },
                {
                    q: "Best pattern for immediate user-facing payment confirmation?",
                    opts: [
                        "Event-Driven",
                        "Shared Data",
                        "Synchronous REST/gRPC",
                        "Async queue",
                    ],
                    correct: 2,
                    explain:
                        "When the user actively waits for a result before the UI can proceed, synchronous communication is correct.",
                },
                {
                    q: "gRPC advantage over REST for internal services?",
                    opts: [
                        "Human-readable JSON",
                        "Binary Protocol Buffers + HTTP/2 + polyglot IDL = 5x faster",
                        "Simpler setup",
                        "Better browser support",
                    ],
                    correct: 1,
                    explain:
                        "gRPC's binary encoding, HTTP/2 multiplexing, and IDL-generated clients make it significantly faster for internal service-to-service communication.",
                },
            ];

            /* ── QUIZ HELPER ───────────────────────────────────── */
            function buildQuiz(container, questions, prefix, onAllCorrect) {
                let correctCount = 0;
                let answeredCorrectly = new Set();

                questions.forEach((q, qi) => {
                    const card = document.createElement("div");
                    card.className = "quiz-card";
                    card.innerHTML = `<div class="quiz-q"><span class="quiz-q-num">Q${qi + 1}</span>${q.q}</div>
      <div class="quiz-options" id="${prefix}-opts-${qi}">${q.opts.map((o, oi) => `<button class="quiz-btn" data-qi="${qi}" data-oi="${oi}"><span class="quiz-letter">${String.fromCharCode(65 + oi)}.</span>${o}</button>`).join("")}</div>
      <div class="quiz-feedback" id="${prefix}-fb-${qi}"></div>`;
                    container.appendChild(card);
                });

                container.addEventListener("click", (e) => {
                    const btn = e.target.closest(".quiz-btn");
                    if (!btn) return;
                    const qi = +btn.dataset.qi,
                        oi = +btn.dataset.oi,
                        q = questions[qi];

                    if (answeredCorrectly.has(qi)) return;

                    const optsEl = container.querySelector(
                        `#${prefix}-opts-${qi}`,
                    );
                    const fbEl = container.querySelector(`#${prefix}-fb-${qi}`);

                    optsEl.querySelectorAll(".quiz-btn").forEach((b) => {
                        b.disabled = true;
                        b.style.opacity = "0.35";
                    });

                    const ok = oi === q.correct;
                    btn.style.opacity = "1";
                    btn.classList.add(ok ? "correct" : "wrong");

                    fbEl.className = `quiz-feedback show ${ok ? "correct" : "wrong"}`;
                    fbEl.innerHTML = `<span class="fb-label ${ok ? "ok" : "bad"}">${ok ? "✓ Correct." : "✗ Incorrect."}</span><span class="fb-text">${q.explain}</span>`;

                    if (!ok) {
                        const rb =
                            optsEl.querySelectorAll(".quiz-btn")[q.correct];
                        rb.style.opacity = "1";
                        rb.classList.add("correct");

                        setTimeout(() => {
                            optsEl
                                .querySelectorAll(".quiz-btn")
                                .forEach((b) => {
                                    b.disabled = false;
                                    b.style.opacity = "";
                                    b.classList.remove("correct", "wrong");
                                });
                            fbEl.className = "quiz-feedback";
                        }, 2000);
                    } else {
                        answeredCorrectly.add(qi);
                        correctCount++;
                        if (correctCount === questions.length && onAllCorrect) {
                            onAllCorrect();
                        }
                    }
                });
            }

            /* ── NAVIGATION + LOCK ─────────────────────────────── */
            const unlocked = new Set(["intro", "overview-diagram", "video"]);
            const viewed = new Set();

            function getAllSects() {
                return Array.from(
                    document.querySelectorAll(".content-section"),
                );
            }
            function getAllBtns() {
                return Array.from(document.querySelectorAll(".sidebar-btn"));
            }

            function updateProgress() {
                const excluded = ["overview-diagram", "video", "quiz"];
                let sections = getAllSects().filter(
                    (s) => !excluded.includes(s.id),
                );
                const total = sections.length;
                let validViewed = 0;
                viewed.forEach((id) => {
                    if (!excluded.includes(String(id))) validViewed++;
                });
                const p = total ? Math.round((validViewed / total) * 100) : 0;
                const fill = document.getElementById("progress-fill");
                const pct = document.getElementById("progress-pct");
                if (fill) fill.style.width = p + "%";
                if (pct) pct.textContent = p + "%";
            }

            function updateSidebar(currentId) {
                getAllBtns().forEach((b) => {
                    const t = b.getAttribute("data-target") || "";
                    b.classList.remove("active", "done", "locked");
                    if (t === currentId) {
                        b.classList.add("active");
                        return;
                    }
                    if (!unlocked.has(t)) {
                        b.classList.add("locked");
                        return;
                    }
                    if (viewed.has(t)) b.classList.add("done");
                });
            }

            function show(id) {
                if (!unlocked.has(id)) return;
                getAllSects().forEach((s) => s.classList.remove("visible"));
                const sect = document.getElementById(id);
                if (sect) {
                    sect.classList.add("visible");
                    window.scrollTo({ top: 0, behavior: "smooth" });
                }
                viewed.add(id);
                updateSidebar(id);
                updateProgress();
            }

            /* ── GATE INJECTION ────────────────────────────────── */
            function injectGates() {
                Object.entries(GATE).forEach(([moduleId, g]) => {
                    const sect = document.getElementById(moduleId);
                    if (!sect) return;
                    const el = document.createElement("div");
                    el.className = "module-gate";
                    el.innerHTML = `
      <div class="module-gate-header" style="margin-bottom:20px;"><span class="gate-icon">🔐</span>CHECKPOINT — Answer all 3 questions correctly to unlock the next module</div>
      <div class="quiz-wrap" id="gate-app-${moduleId}" style="padding:20px;margin-bottom:20px;border:none;background:transparent;"></div>
      <div style="text-align:right;">
        <button type="button" class="gate-next-btn" id="gate-next-${moduleId}" data-next="${g.next}" style="display:none; position:relative; z-index:50;">
          Unlock: ${g.next.replace(/-/g, " ").replace(/\b\w/g, (c) => c.toUpperCase())} →
        </button>
      </div>`;
                    sect.appendChild(el);

                    const container = el.querySelector(`#gate-app-${moduleId}`);
                    buildQuiz(container, g.qs, `g-${moduleId}`, () => {
                        const nextBtn = el.querySelector(
                            `#gate-next-${moduleId}`,
                        );
                        if (nextBtn instanceof HTMLElement) {
                            nextBtn.style.display = "inline-flex";
                            nextBtn.classList.add("show");
                        }

                        unlocked.add(g.next);
                        updateSidebar(g.next);

                        if (nextBtn instanceof HTMLElement) {
                            nextBtn.addEventListener("click", () =>
                                show(g.next),
                            );
                        }
                    });
                });
            }

            /* ── INJECT EXTRA SECTIONS ─────────────────────────── */
            function injectExtraSections() {
                const ca = document.querySelector(".content-area");
                if (!ca) return;

                // Video
                const videoSect = document.createElement("section");
                videoSect.id = "video";
                videoSect.className = "content-section";
                videoSect.innerHTML = `
    <div class="section-label"><span class="section-label-dot"></span>Resource · Video</div>
    <h1 class="section-title">Short Video</h1>
    <p class="section-lead">A concise visual walkthrough to anchor your understanding of microservice communication patterns.</p>
    <div class="video-card">
      <div class="video-thumb" data-vid="MvUpdD3D2jY" style="background:linear-gradient(135deg,rgba(10,14,31,0.9),rgba(30,20,60,0.9));min-height:200px;display:flex;align-items:center;justify-content:center;">
        <button class="video-play" type="button" aria-label="Play">▶</button>
      </div>
      <div class="video-info"><h3>Microservice Communication Patterns</h3><p>ByteByteGo — concise visual overview · ~8 min</p></div>
    </div>`;
                videoSect
                    .querySelector(".video-thumb")
                    ?.addEventListener("click", function () {
                        const id = this.dataset.vid;
                        const f = document.createElement("iframe");
                        f.src = `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0`;
                        f.className = "video-iframe";
                        f.allow = "autoplay; encrypted-media";
                        f.allowFullscreen = true;
                        this.replaceWith(f);
                    });
                ca.appendChild(videoSect);

                // Final Quiz
                const quizSect = document.createElement("section");
                quizSect.id = "quiz";
                quizSect.className = "content-section";
                quizSect.innerHTML = `
    <div class="section-label"><span class="section-label-dot"></span>Final Quiz</div>
    <h1 class="section-title">Final Knowledge Check</h1>
    <p class="section-lead">${FINAL_Q.length} questions across all modules.</p>
    <div class="quiz-wrap" id="quiz-app"><p class="quiz-heading">Knowledge Check</p><p class="quiz-sub">${FINAL_Q.length} questions · Select an answer to reveal the explanation</p></div>`;
                ca.appendChild(quizSect);
                buildQuiz(
                    quizSect.querySelector("#quiz-app"),
                    FINAL_Q,
                    "fq",
                    undefined,
                );
            }

            /* ── AI CHATBOX ────────────────────────────────────── */
            function initChatbox() {
                const root = document.querySelector("[data-chatbox-root]");
                const toggle = root?.querySelector("[data-chatbox-toggle]");
                const close = root?.querySelector("[data-chatbox-close]");
                const panel = root?.querySelector("[data-chatbox-panel]");
                const msgBox = root?.querySelector("[data-chatbox-messages]");
                const form = root?.querySelector("[data-chatbox-form]");
                const input = form?.querySelector("input");
                if (!root) return;

                let msgs = [
                    {
                        role: "assistant",
                        content:
                            "Hi! Ask me anything about microservice communication patterns covered in this course.",
                    },
                ];

                const esc = (t) =>
                    t
                        .replaceAll("&", "&amp;")
                        .replaceAll("<", "&lt;")
                        .replaceAll(">", "&gt;");
                const render = () => {
                    if (!msgBox) return;
                    msgBox.innerHTML = msgs
                        .map(
                            (m) =>
                                `<article class="chat-msg chat-msg-${m.role}"><p>${esc(m.content)}</p></article>`,
                        )
                        .join("");
                    msgBox.scrollTop = msgBox.scrollHeight;
                };

                toggle?.addEventListener("click", () => {
                    const open = !root.classList.contains("is-open");
                    root.classList.toggle("is-open", open);
                    panel?.setAttribute("aria-hidden", String(!open));
                    toggle?.setAttribute("aria-expanded", String(open));
                    if (open) setTimeout(() => input?.focus(), 20);
                });
                close?.addEventListener("click", () => {
                    root.classList.remove("is-open");
                    panel?.setAttribute("aria-hidden", "true");
                });

                form?.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    if (!input) return;
                    const text = input.value.trim();
                    if (!text) return;
                    input.value = "";
                    msgs.push({ role: "user", content: text });
                    msgs.push({ role: "assistant", content: "Thinking..." });
                    render();
                    try {
                        const r = await fetch("/api/chat", {
                            method: "POST",
                            headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({
                                messages: msgs.filter(
                                    (m) => m.content !== "Thinking...",
                                ),
                                maxContextChunks: 6,
                            }),
                        });
                        const d = await r.json();
                        msgs.pop();
                        msgs.push({
                            role: "assistant",
                            content: r.ok
                                ? d.answer || "No answer."
                                : d?.error?.message || "Error.",
                        });
                    } catch {
                        msgs.pop();
                        msgs.push({
                            role: "assistant",
                            content: "Network error.",
                        });
                    }
                    render();
                });
                render();
            }

            /* ── BOOT ──────────────────────────────────────────── */
            document.addEventListener("DOMContentLoaded", () => {
                injectExtraSections();
                injectGates();

                getAllBtns().forEach((b) => {
                    const target = b.getAttribute("data-target") || "";
                    b.addEventListener("click", () => show(target));
                    if (!unlocked.has(target)) b.classList.add("locked");
                });
                document
                    .getElementById("start-btn")
                    ?.addEventListener("click", () => show("intro"));
                document.querySelectorAll(".top-nav-link").forEach((link) => {
                    link.addEventListener("click", (e) => {
                        e.preventDefault();
                        const target = link.getAttribute("data-target");
                        if (target) {
                            unlocked.add(target);
                            show(target);
                            updateSidebar(target);
                        }
                    });
                });

                document.querySelectorAll(".free-nav-btn").forEach((btn) => {
                    btn.addEventListener("click", () => {
                        const target = btn.getAttribute("data-next");
                        if (target) {
                            unlocked.add(target);
                            show(target);
                            updateSidebar(target);
                        }
                    });
                });

                initChatbox();
                show("intro");
            });
        </script>
    </body>
</html>
