                    <!-- ═══ MODULE 5: ASYNC NON-BLOCKING ═══ -->
                    <section id="async" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 05 ·
                            Communication Styles
                        </div>
                        <h1 class="section-title">Asynchronous Non-Blocking</h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                The caller sends messages without waiting,
                                enabling loose decoupling. The sender is free
                                immediately after sending. Three sub-patterns
                                exist: <strong style="color:var(--teal)"
                                    >Shared Data</strong
                                >, <strong style="color:var(--amber)"
                                    >Async Request-Response</strong
                                >, and <strong style="color:var(--purple)"
                                    >Event-Driven</strong
                                >.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong
                                    >Sending an order update without blocking
                                    the UI</strong
                                > — the user sees "Order submitted!" immediately while
                                the system processes asynchronously in the background.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col">
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;"
                                    >
                                        <div class="d-node d-node-purple">
                                            Sender
                                        </div>
                                        <span class="d-arrow"
                                            >→ publishes →</span
                                        >
                                        <div class="d-node d-node-accent">
                                            Message Broker / Queue
                                        </div>
                                        <span class="d-arrow">→ delivers →</span
                                        >
                                        <div class="d-node d-node-teal">
                                            Receiver<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >(Async Process)</small
                                            >
                                        </div>
                                    </div>
                                    <div
                                        style="text-align:center;margin-top:14px;font-size:12px;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        No direct response path — Sender is free
                                        immediately.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🎬</div>
                                <div>
                                    <div class="rw-label">
                                        Netflix — Content Ingestion
                                    </div>
                                    <div class="rw-body">
                                        Netflix's content ingestion pipeline
                                        uses async for video encoding. Uploads
                                        are accepted immediately and processing
                                        (transcoding to 4K, HDR, etc.) happens
                                        in background workers without blocking
                                        the upload service.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Aspect</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Coupling</td><td class="pros"
                                            >Loose — no temporal dependency</td
                                        ><td class="cons"
                                            >Harder to trace distributed flows</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Scalability</td><td class="pros"
                                            >Absorbs traffic spikes via queue</td
                                        ><td class="cons"
                                            >Requires broker infra
                                            (Kafka/RabbitMQ)</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Consistency</td><td class="pros"
                                            >Resilient to downstream downtime</td
                                        ><td class="cons"
                                            >Eventual consistency only</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 6: SHARED DATA ═══ -->
                    <section id="shared-data" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 06 ·
                            Async Patterns
                        </div>
                        <h1 class="section-title">
                            Communication Through Common Data
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Services share data via a common store (e.g.,
                                database or file system). One service writes
                                data; another polls or reads it periodically.
                                Simple to implement for large data transfers,
                                but introduces high latency due to polling and
                                coupling via schema.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong>Export service writes CSV to S3;</strong
                                > the import service polls S3 every 5 minutes, detects
                                new files, and processes them in batch.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:14px;">
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;"
                                    >
                                        <div class="d-node d-node-teal">
                                            Service A
                                        </div>
                                        <span class="d-arrow"
                                            >─── Write ──→</span
                                        >
                                        <div class="d-node d-node-amber">
                                            Shared DB / S3
                                        </div>
                                    </div>
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;padding-left:24px;"
                                    >
                                        <div class="d-node d-node-purple">
                                            Service B
                                        </div>
                                        <span class="d-arrow"
                                            >←── Poll / Read ───</span
                                        >
                                        <div class="d-node d-node-amber">
                                            Shared DB / S3
                                        </div>
                                    </div>
                                    <div
                                        style="text-align:center;font-size:11px;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        Service B reads at its own pace → high
                                        latency, no direct connection.
                                    </div>
                                </div>
                            </div>
                            <div class="terminal">
                                <div class="terminal-header">
                                    <span class="t-dot t-dot-r"></span><span
                                        class="t-dot t-dot-y"></span><span
                                        class="t-dot t-dot-g"></span>
                                    <span class="terminal-filename"
                                        >shared-data.cs</span
                                    >
                                </div>
                                <div class="terminal-body">
                                    <pre>// Writer service
context.Ledger.Add(new LedgerEntry &#123; Type = "credit", Amount = 100 &#125;);
await context.SaveChangesAsync();

// Reader service polls for new entries
var recent = await context.Ledger
    .Where(x =&gt; x.CreatedAt &gt; DateTime.UtcNow.AddMinutes(-5))
    .ToListAsync();</pre>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">✈️</div>
                                <div>
                                    <div class="rw-label">
                                        Airbnb — Data Pipelines
                                    </div>
                                    <div class="rw-body">
                                        Airbnb's analytics pipelines use Amazon
                                        S3 for batch data exchange — one service
                                        exports nightly data exports, another
                                        processes them in large Spark batch jobs
                                        the following morning.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Aspect</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Simplicity</td><td class="pros"
                                            >Simple to implement with standard
                                            DB</td
                                        ><td class="cons"
                                            >Polling wastes resources</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Latency</td><td class="pros"
                                            >Works for batch/large data</td
                                        ><td class="cons"
                                            >High latency due to poll interval</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Coupling</td><td class="pros"
                                            >No direct service dependency</td
                                        ><td class="cons"
                                            >Coupled via shared data schema</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 7: ASYNC REQUEST-RESPONSE ═══ -->
                    <section id="async-rr" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 07 ·
                            Async Patterns
                        </div>
                        <h1 class="section-title">
                            Asynchronous Request-Response
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Uses message queues for non-blocking requests
                                with <strong style="color:var(--accent-2)"
                                    >correlation IDs</strong
                                > to match responses back to their original requests.
                                Eliminates temporal coupling while still delivering
                                a result — but requires state management and a reply
                                queue.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong
                                    >Order service queues a shipping request</strong
                                > with a unique correlation ID. The shipping service
                                processes it and sends the response to a reply queue.
                                Order service reads the reply queue and matches it
                                using the correlation ID.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:12px;">
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;"
                                    >
                                        <div class="d-node d-node-accent">
                                            Order Service
                                        </div>
                                        <span class="d-arrow"
                                            >→ Request + CorrID →</span
                                        >
                                        <div class="d-node d-node-amber">
                                            Queue
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-teal">
                                            Shipping Service
                                        </div>
                                    </div>
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;justify-content:flex-end;"
                                    >
                                        <div class="d-node d-node-accent">
                                            Order Service
                                        </div>
                                        <span class="d-arrow"
                                            >← Response + CorrID ←</span
                                        >
                                        <div class="d-node d-node-amber">
                                            Reply Queue
                                        </div>
                                        <span class="d-arrow">←</span>
                                        <div class="d-node d-node-teal">
                                            Shipping Service
                                        </div>
                                    </div>
                                    <div
                                        style="text-align:center;font-size:11px;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        Correlation ID links the async response
                                        to the original request.
                                    </div>
                                </div>
                            </div>
                            <div class="terminal">
                                <div class="terminal-header">
                                    <span class="t-dot t-dot-r"></span><span
                                        class="t-dot t-dot-y"></span><span
                                        class="t-dot t-dot-g"></span>
                                    <span class="terminal-filename"
                                        >async-rr.cs</span
                                    >
                                </div>
                                <div class="terminal-body">
                                    <pre>// API returns 202 Accepted immediately
app.MapPost("/video/encode", async (Video v) =&gt; &#123;
    var id = Guid.NewGuid();
    await queue.SendAsync(new EncodeTask(id, v.Url));
    return Results.Accepted($"/video/encode/&#123;id&#125;");
&#125;);

// Client polls: GET /video/encode/&#123;id&#125; → 200 OK, Status: DONE</pre>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🚙</div>
                                <div>
                                    <div class="rw-label">
                                        Uber — Driver Matching
                                    </div>
                                    <div class="rw-body">
                                        Uber's matching system queues
                                        driver-rider match requests
                                        asynchronously to handle massive load
                                        spikes during peak hours without
                                        blocking the requesting service.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Aspect</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Coupling</td><td class="pros"
                                            >No temporal coupling — async</td
                                        ><td class="cons"
                                            >Requires correlation ID state
                                            management</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Reliability</td><td class="pros"
                                            >Queue buffers load spikes</td
                                        ><td class="cons"
                                            >At-least-once delivery needs
                                            idempotency</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Complexity</td><td class="pros"
                                            >Good for long-running tasks</td
                                        ><td class="cons"
                                            >More complex than direct sync calls</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 8: EVENT-DRIVEN ═══ -->
                    <section id="event-driven" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 08 ·
                            Async Patterns
                        </div>
                        <h1 class="section-title">
                            Event-Driven Communication
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Services emit events via brokers; consumers
                                subscribe and react. Promotes loose coupling
                                through <strong style="color:var(--purple)"
                                    >inversion of responsibility</strong
                                > — the producer emits facts (past-tense events) and
                                doesn't dictate what consumers should do. Adds complexity
                                in event ordering and delivery guarantees.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong
                                    >Order service emits <code
                                        style="color:var(--teal)"
                                        >OrderShipped</code
                                    ></strong
                                > event. The notification service subscribes and sends
                                an email. The inventory service subscribes and updates
                                stock. Neither consumer is known to the producer.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:12px;">
                                    <div
                                        class="d-row"
                                        style="gap:8px;flex-wrap:wrap;"
                                    >
                                        <div class="d-node d-node-teal">
                                            Order Service<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >Publish OrderShipped</small
                                            >
                                        </div>
                                        <span class="d-arrow">→ Event →</span>
                                        <div class="d-node d-node-accent">
                                            Kafka / SNS Broker<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >(Topic)</small
                                            >
                                        </div>
                                    </div>
                                    <div
                                        style="padding-left:40px;font-size:12px;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        ↓ Subscribers
                                    </div>
                                    <div
                                        class="d-row"
                                        style="gap:12px;flex-wrap:wrap;"
                                    >
                                        <div class="d-node d-node-amber">
                                            Notification Service<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >→ sends email</small
                                            >
                                        </div>
                                        <div class="d-node d-node-purple">
                                            Inventory Service<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >→ updates stock</small
                                            >
                                        </div>
                                        <div class="d-node d-node-coral">
                                            Analytics Service<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >→ records event</small
                                            >
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="terminal">
                                <div class="terminal-header">
                                    <span class="t-dot t-dot-r"></span><span
                                        class="t-dot t-dot-y"></span><span
                                        class="t-dot t-dot-g"></span>
                                    <span class="terminal-filename"
                                        >event-driven.cs</span
                                    >
                                </div>
                                <div class="terminal-body">
                                    <pre>// Producer: past-tense event name
public record OrderCreated(int OrderId);
await bus.Publish(new OrderCreated(123));

// Consumer: reacts independently, no coupling to producer
public class OrderConsumer : IConsumer&lt;OrderCreated&gt; &#123;
    public Task Consume(ConsumeContext&lt;OrderCreated&gt; ctx) =&gt;
        NotifyShipping(ctx.Message.OrderId);
&#125;</pre>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">📦</div>
                                <div>
                                    <div class="rw-label">
                                        Amazon — Order Processing
                                    </div>
                                    <div class="rw-body">
                                        Amazon's order system emits events for
                                        inventory updates, consumed by
                                        warehouse, analytics, and shipping
                                        services simultaneously — none of which
                                        the Order Service needs to know about.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Aspect</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Coupling</td><td class="pros"
                                            >Zero consumer coupling — fully
                                            decoupled</td
                                        ><td class="cons"
                                            >Hard to reason about overall flow</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Scalability</td><td class="pros"
                                            >Fan-out to many consumers</td
                                        ><td class="cons"
                                            >Event ordering is complex</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Reliability</td><td class="pros"
                                            >Consumers can retry independently</td
                                        ><td class="cons"
                                            >Idempotency required for duplicates</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 9: TECHNOLOGY CHOICES ═══ -->
                    <section id="technology" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 09 ·
                            Technology & Summary
                        </div>
                        <h1 class="section-title">Technology Choices</h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Technologies like <strong
                                    style="color:var(--amber)"
                                    >RPC (gRPC/SOAP)</strong
                                >, <strong style="color:var(--teal)"
                                    >REST</strong
                                >, and <strong style="color:var(--purple)"
                                    >message brokers (Kafka/RabbitMQ)</strong
                                > implement the patterns. Choose based on: backward
                                compatibility needs, explicit interface contracts,
                                consumer simplicity, and encapsulation requirements.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong>gRPC</strong> for efficient RPC between internal
                                services in a polyglot environment. <strong
                                    >REST</strong
                                > for public-facing APIs where developer simplicity
                                matters. <strong>Kafka</strong> for high-throughput
                                event streaming.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:20px;">
                                    <div>
                                        <div
                                            style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--amber);font-family:var(--font-mono);margin-bottom:8px;"
                                        >
                                            RPC (gRPC / SOAP)
                                        </div>
                                        <div
                                            class="d-row"
                                            style="gap:8px;flex-wrap:wrap;"
                                        >
                                            <div class="d-node d-node-amber">
                                                Client Stub
                                            </div>
                                            <span class="d-arrow"
                                                >→ Network →</span
                                            >
                                            <div class="d-node d-node-amber">
                                                Server (Schema-Driven)
                                            </div>
                                        </div>
                                    </div>
                                    <div>
                                        <div
                                            style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--teal);font-family:var(--font-mono);margin-bottom:8px;"
                                        >
                                            REST
                                        </div>
                                        <div
                                            class="d-row"
                                            style="gap:8px;flex-wrap:wrap;"
                                        >
                                            <div class="d-node d-node-teal">
                                                Client
                                            </div>
                                            <span class="d-arrow"
                                                >→ HTTP Method + URI →</span
                                            >
                                            <div class="d-node d-node-teal">
                                                Resource
                                            </div>
                                        </div>
                                    </div>
