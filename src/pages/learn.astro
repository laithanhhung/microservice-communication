---
import "../styles/global.css";
import SystemDiagram from "../components/SystemDiagram.astro";
const chapters = [
    {
        num: "01",
        title: "Foundations",
        modules: [
            { id: "intro", label: "Introduction" },
            { id: "challenges", label: "Challenges" },
            { id: "patterns", label: "Core Patterns" },
        ],
    },
    {
        num: "02",
        title: "Communication Styles",
        modules: [
            { id: "sync", label: "Synchronous Blocking" },
            { id: "async", label: "Async Non-Blocking" },
        ],
    },
    {
        num: "03",
        title: "Async Patterns",
        modules: [
            { id: "shared-data", label: "Shared Data" },
            { id: "async-rr", label: "Async Request-Response" },
            { id: "event-driven", label: "Event-Driven" },
        ],
    },
    {
        num: "04",
        title: "Technology & Summary",
        modules: [
            { id: "technology", label: "Technology Choices" },
            { id: "summary", label: "Summary & Decision" },
        ],
    },
    {
        num: "05",
        title: "Assessment",
        modules: [{ id: "quiz", label: "Final Quiz" }],
    },
];
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Microservice Communication Patterns</title>
        <meta
            name="description"
            content="Interactive mini-course on Microservice Communication Patterns for distributed systems engineers."
        />
        <link rel="icon" type="image/png" href="/logo.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <div class="app-shell">
            <!-- TOPBAR -->
            <nav class="topbar">
                <div class="topbar-brand">
                    <img
                        src="/logo.png"
                        alt="Logo"
                        class="w-8 h-8 object-contain"
                    />
                    <span>Microservice Patterns</span>
                </div>
                <div class="topbar-nav">
                    <a href="#" class="top-nav-link" data-target="intro">Docs</a
                    >
                    <a
                        href="#"
                        class="top-nav-link"
                        data-target="overview-diagram">Architecture</a
                    >
                    <a href="#" class="top-nav-link" data-target="video"
                        >Video</a
                    >
                </div>
                <button class="topbar-cta" id="start-btn"
                    >Start Learning →</button
                >
            </nav>

            <!-- PROGRESS BAR -->
            <div class="progress-bar-wrap">
                <div class="progress-bar-inner">
                    <span
                        style="display:flex;align-items:center;gap:8px;font-size:11px;"
                    >
                        <svg
                            style="width:13px;height:13px;color:var(--accent)"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            ><path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg
                        >
                        Progress
                    </span>
                    <span
                        id="progress-pct"
                        style="color:var(--accent);font-family:var(--font-mono);font-weight:700;font-size:11px;"
                        >0%</span
                    >
                </div>
                <div class="progress-track">
                    <div class="progress-fill" id="progress-fill"></div>
                </div>
            </div>

            <!-- LEARN SHELL -->
            <div class="learn-shell">
                <!-- SIDEBAR -->
                <aside class="sidebar">
                    {
                        chapters.map((ch) => (
                            <div>
                                <div class="sidebar-chapter-title">
                                    <span class="sidebar-chapter-num">
                                        {ch.num}
                                    </span>
                                    {ch.title}
                                </div>
                                <ul class="sidebar-list">
                                    {ch.modules.map((m) => (
                                        <li>
                                            <button
                                                class="sidebar-btn"
                                                data-target={m.id}
                                            >
                                                <span>{m.label}</span>
                                                <span class="sidebar-dot" />
                                            </button>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        ))
                    }
                    <div class="sidebar-footer">
                        <span>v2.0</span>
                        <div style="display:flex;align-items:center;gap:6px;">
                            <span class="sidebar-status-dot"></span><span
                                >Online</span
                            >
                        </div>
                    </div>
                </aside>

                <!-- CONTENT -->
                <main class="content-area">
                    <!-- ═══ MODULE 1: INTRODUCTION ═══ -->
                    <section id="intro" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 01 ·
                            Introduction
                        </div>
                        <h1 class="section-title">
                            Introduction to Microservices
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Microservices architecture decomposes
                                applications into independent services that must
                                communicate to form a cohesive system.
                                Communication occurs over networks, introducing
                                challenges like latency and failures, unlike
                                in-process calls in monoliths. Selecting the
                                right pattern is crucial for performance and
                                scalability.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                In an e-commerce system, the <strong
                                    >order service</strong
                                > communicates with <strong>payment</strong> and <strong
                                    >inventory services</strong
                                > over the network to complete a transaction — unlike
                                a monolith where these are direct function calls.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col">
                                    <div
                                        style="font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-family:var(--font-mono);margin-bottom:10px;"
                                    >
                                        Monolith
                                    </div>
                                    <div class="d-row">
                                        <div class="d-node d-node-teal">
                                            Client
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-teal">
                                            Single Process<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >(In-Process Calls)</small
                                            >
                                        </div>
                                    </div>
                                    <div
                                        style="height:1px;background:var(--stroke);margin:20px 0;width:50%;align-self:center;"
                                    >
                                    </div>
                                    <div
                                        style="font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-family:var(--font-mono);margin-bottom:10px;"
                                    >
                                        Microservices
                                    </div>
                                    <div
                                        class="d-row"
                                        style="flex-wrap:wrap;gap:8px;"
                                    >
                                        <div class="d-node d-node-accent">
                                            Client
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-purple">
                                            Order Service
                                        </div>
                                        <span class="d-arrow">→ Network →</span>
                                        <div class="d-node d-node-teal">
                                            Payment Service
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🌐</div>
                                <div>
                                    <div class="rw-label">Netflix</div>
                                    <div class="rw-body">
                                        Netflix uses microservices for
                                        streaming, where UI services communicate
                                        with recommendation engines to
                                        personalize content for 238M+
                                        subscribers.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Approach</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Monolith</td><td class="pros"
                                            >Fast in-process calls, simple</td
                                        ><td class="cons"
                                            >Tight coupling, hard to scale parts</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Microservices</td><td class="pros"
                                            >Independent deploy, scalable</td
                                        ><td class="cons"
                                            >Network overhead, distributed
                                            failures</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 2: CHALLENGES ═══ -->
                    <section id="challenges" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 02 ·
                            Challenges
                        </div>
                        <h1 class="section-title">
                            Challenges in Communication
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Inter-process communication in microservices
                                differs from in-process method calls, leading to
                                issues in performance, interface modifications,
                                and error handling. What was a simple function
                                call becomes a remote network call with
                                serialization overhead, potential timeouts, and
                                backward compatibility concerns.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                A service call over a network adds <strong
                                    >serialization overhead</strong
                                > — the object must be converted to JSON/binary, transmitted,
                                and deserialized on the other side — unlike passing
                                a memory reference in a monolith.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:14px;">
                                    <div
                                        style="font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted);font-family:var(--font-mono);margin-bottom:4px;"
                                    >
                                        Three Core Challenges
                                    </div>
                                    <div
                                        class="d-row"
                                        style="flex-wrap:wrap;gap:12px;"
                                    >
                                        <div
                                            style="flex:1;min-width:140px;padding:14px;background:rgba(245,158,11,0.05);border:1px solid rgba(245,158,11,0.15);border-radius:10px;"
                                        >
                                            <div
                                                style="color:var(--amber);font-weight:700;font-size:12px;margin-bottom:6px;"
                                            >
                                                ⚡ Performance
                                            </div>
                                            <div
                                                style="font-size:12px;color:var(--muted);line-height:1.6;"
                                            >
                                                Network Latency + Serialization
                                                Cost
                                            </div>
                                        </div>
                                        <div
                                            style="flex:1;min-width:140px;padding:14px;background:rgba(168,85,247,0.05);border:1px solid rgba(168,85,247,0.15);border-radius:10px;"
                                        >
                                            <div
                                                style="color:var(--purple);font-weight:700;font-size:12px;margin-bottom:6px;"
                                            >
                                                🔌 Interface Changes
                                            </div>
                                            <div
                                                style="font-size:12px;color:var(--muted);line-height:1.6;"
                                            >
                                                Backward Compatibility Issues
                                            </div>
                                        </div>
                                        <div
                                            style="flex:1;min-width:140px;padding:14px;background:rgba(244,63,94,0.05);border:1px solid rgba(244,63,94,0.15);border-radius:10px;"
                                        >
                                            <div
                                                style="color:var(--coral);font-weight:700;font-size:12px;margin-bottom:6px;"
                                            >
                                                ❌ Error Handling
                                            </div>
                                            <div
                                                style="font-size:12px;color:var(--muted);line-height:1.6;"
                                            >
                                                Network Timeouts + Service
                                                Outages
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🛍️</div>
                                <div>
                                    <div class="rw-label">
                                        Amazon — Black Friday
                                    </div>
                                    <div class="rw-body">
                                        Amazon's e-commerce platform faces
                                        cascading performance challenges during
                                        Black Friday — slow inter-service calls
                                        can block upstream services and bring
                                        down entire checkout flows.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Challenge</th><th>Impact</th><th
                                            >Mitigation</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Network Latency</td><td
                                            class="cons">Adds 1–5ms+ per hop</td
                                        ><td class="pros"
                                            >Async processing, caching</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Backward Compatibility</td><td
                                            class="cons"
                                            >Breaking changes break consumers</td
                                        ><td class="pros"
                                            >API versioning, contract testing</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Error Handling</td><td class="cons"
                                            >Cascading failures</td
                                        ><td class="pros"
                                            >Circuit breakers, timeouts</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 3: CORE PATTERNS ═══ -->
                    <section id="patterns" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 03 ·
                            Core Patterns
                        </div>
                        <h1 class="section-title">
                            Core Communication Patterns
                        </h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                Patterns are categorized into <strong
                                    style="color:var(--amber)"
                                    >synchronous blocking</strong
                                > (caller waits for response) and <strong
                                    style="color:var(--purple)"
                                    >asynchronous non-blocking</strong
                                > (caller continues without waiting). This taxonomy
                                helps choose based on coupling and latency needs.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong>Synchronous:</strong> for immediate validation
                                (user submits a form, waits for confirmation). <strong
                                    >Asynchronous:</strong
                                > for background processing (video encoding, email
                                sending).
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col">
                                    <div
                                        class="d-node d-node-accent"
                                        style="align-self:center;padding:10px 28px;"
                                    >
                                        Microservice Patterns
                                    </div>
                                    <div
                                        class="d-row"
                                        style="justify-content:center;gap:48px;margin-top:6px;"
                                    >
                                        <span
                                            class="d-arrow"
                                            style="font-size:20px;">↙</span
                                        >
                                        <span
                                            class="d-arrow"
                                            style="font-size:20px;">↘</span
                                        >
                                    </div>
                                    <div
                                        class="d-row"
                                        style="justify-content:space-around;flex-wrap:wrap;gap:16px;"
                                    >
                                        <div style="flex:1;min-width:160px;">
                                            <div
                                                class="d-node d-node-amber"
                                                style="margin-bottom:10px;"
                                            >
                                                Synchronous Blocking
                                            </div>
                                            <div class="d-row">
                                                <span class="d-arrow">→</span
                                                ><div
                                                    class="d-node d-node-teal"
                                                >
                                                    Request-Response
                                                </div>
                                            </div>
                                        </div>
                                        <div style="flex:1;min-width:200px;">
                                            <div
                                                class="d-node d-node-purple"
                                                style="margin-bottom:10px;"
                                            >
                                                Async Non-Blocking
                                            </div>
                                            <div class="d-col" style="gap:8px;">
                                                <div class="d-row">
                                                    <span class="d-arrow"
                                                        >→</span
                                                    ><div
                                                        class="d-node d-node-teal"
                                                    >
                                                        Shared Data
                                                    </div>
                                                </div>
                                                <div class="d-row">
                                                    <span class="d-arrow"
                                                        >→</span
                                                    ><div
                                                        class="d-node d-node-teal"
                                                    >
                                                        Async Request-Response
                                                    </div>
                                                </div>
                                                <div class="d-row">
                                                    <span class="d-arrow"
                                                        >→</span
                                                    ><div
                                                        class="d-node d-node-teal"
                                                    >
                                                        Event-Driven
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🚗</div>
                                <div>
                                    <div class="rw-label">
                                        Uber — Mixed Patterns
                                    </div>
                                    <div class="rw-body">
                                        Uber uses synchronous communication for
                                        ride requests (immediate response
                                        needed) and asynchronous for driver
                                        notifications (fire-and-forget push
                                        messages).
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Pattern</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Synchronous</td><td class="pros"
                                            >Simple, instant feedback</td
                                        ><td class="cons"
                                            >Temporal coupling, cascading
                                            failures</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Asynchronous</td><td class="pros"
                                            >Decoupled, scalable</td
                                        ><td class="cons"
                                            >Eventual consistency, harder to
                                            debug</td
                                        ></tr
                                    >
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <!-- ═══ MODULE 4: SYNCHRONOUS ═══ -->
                    <section id="sync" class="content-section">
                        <div class="section-label">
                            <span class="section-label-dot"></span>Module 04 ·
                            Communication Styles
                        </div>
                        <h1 class="section-title">Synchronous Blocking</h1>

                        <div class="cb-block">
                            <div class="cb-label cb-label-concept">
                                Concept Explanation
                            </div>
                            <p class="cb-concept">
                                The caller sends a request and blocks until a
                                response arrives, following a request-response
                                model. It's simple to implement and reason
                                about, but creates <strong
                                    style="color:var(--coral)"
                                    >temporal coupling</strong
                                > — both services must be running simultaneously —
                                and risks <strong style="color:var(--coral)"
                                    >cascading failures</strong
                                > in long chains.
                            </p>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-example">Example</div>
                            <div class="cb-example">
                                <strong
                                    >Order service calls payment service</strong
                                > and waits for confirmation before responding to
                                the user. If payment takes 3 seconds, the user waits
                                3 seconds.
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-diagram">
                                Architecture Diagram
                            </div>
                            <div class="diagram-frame">
                                <div class="d-col" style="gap:12px;">
                                    <div
                                        style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        Request Flow (blocks at each hop)
                                    </div>
                                    <div
                                        class="d-row"
                                        style="flex-wrap:wrap;gap:8px;"
                                    >
                                        <div class="d-node d-node-teal">
                                            Client
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-accent">
                                            API Gateway
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-purple">
                                            Order Service
                                        </div>
                                        <span class="d-arrow">→</span>
                                        <div class="d-node d-node-amber">
                                            Payment Service<br /><small
                                                style="font-size:10px;opacity:.6;"
                                                >(Blocks...)</small
                                            >
                                        </div>
                                    </div>
                                    <div
                                        style="font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);font-family:var(--font-mono);"
                                    >
                                        Response Flow (unblocks)
                                    </div>
                                    <div
                                        class="d-row"
                                        style="flex-wrap:wrap;gap:8px;justify-content:flex-end;"
                                    >
                                        <div class="d-node d-node-teal">
                                            Client ✓
                                        </div>
                                        <span class="d-arrow">←</span>
                                        <div class="d-node d-node-accent">
                                            API Gateway
                                        </div>
                                        <span class="d-arrow">←</span>
                                        <div class="d-node d-node-purple">
                                            Order Service
                                        </div>
                                        <span class="d-arrow">←</span>
                                        <div class="d-node d-node-amber">
                                            Payment OK
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="terminal">
                                <div class="terminal-header">
                                    <span class="t-dot t-dot-r"></span><span
                                        class="t-dot t-dot-y"></span><span
                                        class="t-dot t-dot-g"></span>
                                    <span class="terminal-filename"
                                        >sync-call.cs</span
                                    >
                                </div>
                                <div class="terminal-body">
                                    <pre>app.MapGet("/users/&#123;id&#125;", (int id) =&gt;
    Results.Ok(new &#123; Id = id, Name = "Alice" &#125;));

// Caller BLOCKS until response arrives
var res = await http.GetAsync("https://api.example.com/users/123");
res.EnsureSuccessStatusCode();</pre>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-realworld">
                                Real World Application
                            </div>
                            <div class="rw-card" style="margin-bottom:0;">
                                <div class="rw-icon">🏘️</div>
                                <div>
                                    <div class="rw-label">
                                        Airbnb — Booking Availability
                                    </div>
                                    <div class="rw-body">
                                        Airbnb's booking system uses synchronous
                                        calls for real-time availability checks
                                        — the user must wait for the result
                                        before the UI can display whether the
                                        dates are available.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="cb-block">
                            <div class="cb-label cb-label-tradeoffs">
                                Trade-offs
                            </div>
                            <table class="cb-tradeoffs-table">
                                <thead
                                    ><tr
                                        ><th>Aspect</th><th>Pros</th><th
                                            >Cons</th
                                        ></tr
                                    ></thead
                                >
                                <tbody>
                                    <tr
                                        ><td>Simplicity</td><td class="pros"
                                            >Easy to implement and debug</td
                                        ><td class="cons"
                                            >Long sync chains multiply latency</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Reliability</td><td class="pros"
                                            >Immediate failure feedback</td
                                        ><td class="cons"
                                            >Cascading failures if downstream is
                                            down</td
                                        ></tr
                                    >
                                    <tr
                                        ><td>Coupling</td><td class="pros"
                                            >Clear request-response contract</td
                                        ><td class="cons"
                                            >Temporal coupling — both must be
