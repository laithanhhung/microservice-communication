---
import "../styles/global.css";
import CardWrapper from "../components/atoms/CardWrapper.astro";
import Icon from "../components/atoms/Icon.astro";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Microservice Communication Patterns | Course</title>
        <meta
            name="description"
            content="Interactive mini-course on Microservice Communication Patterns for distributed systems engineers."
        />
        <link rel="icon" type="image/png" href="/logo.png" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;600&display=swap"
            rel="stylesheet"
        />
        <style>
            .landing-hero {
                text-align: center;
                padding: 120px 20px 80px;
            }
            .landing-title {
                font-size: clamp(40px, 8vw, 72px);
                font-weight: 700;
                margin-bottom: 24px;
                background: linear-gradient(135deg, var(--cyan), var(--purple));
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }
            .landing-subtitle {
                font-size: 20px;
                color: var(--muted);
                max-width: 600px;
                margin: 0 auto 48px;
                line-height: 1.6;
            }
            .primary-btn {
                display: inline-flex;
                align-items: center;
                gap: 12px;
                padding: 16px 36px;
                border-radius: 999px;
                background: var(--accent);
                color: white;
                font-size: 18px;
                font-weight: 600;
                text-decoration: none;
                transition: all 0.3s;
                box-shadow: 0 0 24px rgba(99, 102, 241, 0.4);
            }
            .primary-btn:hover {
                background: #5558e6;
                transform: translateY(-2px);
                box-shadow: 0 8px 32px rgba(99, 102, 241, 0.6);
            }
        </style>
    </head>
    <body class="bg-[#030712] text-white">
        <div class="flex flex-col min-h-screen">
            <!-- TOPBAR -->
            <nav
                class="topbar sticky top-0 z-50 backdrop-blur-md bg-[#050510]/80 border-b border-[#2e3049]"
            >
                <div class="topbar-brand">
                    <img
                        src="/logo.png"
                        alt="Logo"
                        class="w-8 h-8 object-contain"
                    />
                    <span>Microservice Patterns</span>
                </div>
            </nav>

            <main
                class="flex-1 w-full max-w-6xl mx-auto flex flex-col items-center py-10"
            >
                <section class="landing-hero relative z-10 w-full">
                    <!-- Glowing Background Effect -->
                    <div
                        class="absolute inset-0 top-[-20%] pointer-events-none z-[-1] opacity-50
                        bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))]
                        from-purple-900/20 via-[#030712] to-transparent"
                    >
                    </div>

                    <div
                        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-purple-500/30 bg-purple-500/10 text-purple-300 text-sm font-mono font-bold mb-8 shadow-sm"
                    >
                        <span
                            class="w-2 h-2 rounded-full bg-purple-400 animate-pulse"
                        ></span>
                        v2.0 Interactive Edition
                    </div>

                    <h1 class="landing-title">Master Microservices</h1>

                    <p class="landing-subtitle">
                        Deep dive into synchronous, asynchronous, and
                        event-driven communication patterns in distributed
                        systems through interactive diagrams and gated lessons.
                    </p>

                    <a
                        href="/learn"
                        class="primary-btn hover:scale-105 active:scale-95 duration-200"
                    >
                        Initiate Sequence
                        <svg
                            class="w-5 h-5"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
                        </svg>
                    </a>
                </section>

                <section
                    class="grid grid-cols-1 md:grid-cols-3 gap-8 px-6 lg:px-0 w-full z-10"
                >
                    <CardWrapper
                        title="Patterns & Best Practices"
                        color="cyan"
                        class="min-h-[220px]"
                    >
                        <div
                            class="flex flex-col items-center justify-center text-center w-full h-full gap-4 mt-6"
                        >
                            <div
                                class="w-12 h-12 bg-cyan-900/30 rounded-full flex items-center justify-center"
                            >
                                <Icon name="api" />
                            </div>
                            <p
                                class="text-slate-400 text-sm leading-relaxed max-w-[200px]"
                            >
                                Explore comprehensive guides to architectural
                                communication strategies.
                            </p>
                        </div>
                    </CardWrapper>

                    <CardWrapper
                        title="Interactive Architecture"
                        color="purple"
                        class="min-h-[220px]"
                    >
                        <div
                            class="flex flex-col items-center justify-center text-center w-full h-full gap-4 mt-6"
                        >
                            <div
                                class="w-12 h-12 bg-purple-900/30 rounded-full flex items-center justify-center blur-[1px]"
                            >
                                <Icon name="message-broker" />
                            </div>
                            <p
                                class="text-slate-400 text-sm leading-relaxed max-w-[200px]"
                            >
                                Visualize data flow with our interactive native
                                Astro components.
                            </p>
                        </div>
                    </CardWrapper>

                    <CardWrapper
                        title="Gated Checkpoints"
                        color="green"
                        class="min-h-[220px]"
                    >
                        <div
                            class="flex flex-col items-center justify-center text-center w-full h-full gap-4 mt-6"
                        >
                            <div
                                class="w-12 h-12 bg-green-900/30 rounded-full flex items-center justify-center"
                            >
                                <svg
                                    class="w-6 h-6 text-green-400"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        stroke-width="2"
                                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                                    ></path>
                                </svg>
                            </div>
                            <p
                                class="text-slate-400 text-sm leading-relaxed max-w-[200px]"
                            >
                                Test your knowledge and unlock proceeding
                                sections conditionally.
                            </p>
                        </div>
                    </CardWrapper>
                </section>

                <footer
                    class="mt-20 border-t border-slate-800 w-full text-center py-6 text-slate-500 font-mono text-xs"
                >
                    <p>© 2026 PRN Lab • Built with Astro & Tailwind</p>
                </footer>
            </main>
        </div>
    </body>
</html>
